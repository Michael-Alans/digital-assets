{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "incremental": false,
    "isolatedModules": true,
    "lib": ["es2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleDetection": "force",
    "moduleResolution": "NodeNext",
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../apps/web/*"],
      "@/components/*": ["../../apps/web/components/*"],
      "@/app/*": ["../../apps/web/app/*"],
      "@/lib/*": ["../../apps/web/lib/*"],
      "@app/*": ["../../apps/web/app/*"],
      "@components/*": ["../../apps/web/components/*"],
      "@design-assets/db": ["../db/src"],
      "@design-assets/shared": ["../shared/src"]
    }
  }
}