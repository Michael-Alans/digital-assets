{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["esnext", "dom"],
    "strict": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/web/*"],
      "@/components/*": ["./apps/web/components/*"],
      "@/app/*": ["./apps/web/app/*"],
      "@/lib/*": ["./apps/web/lib/*"],
      "@design-assets/db": ["./packages/db/src"],
      "@design-assets/shared": ["./packages/shared/src"]
    },
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}